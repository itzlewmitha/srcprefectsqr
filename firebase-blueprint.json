{
  "entities": {
    "Prefect": {
      "title": "Prefect",
      "description": "Registered prefect record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "grade": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "token": { "type": "string", "description": "Secure verification token" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "name", "grade", "email", "status", "token"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Immuntable attendance log.",
      "type": "object",
      "properties": {
        "prefectId": { "type": "string" },
        "timestamp": { "type": "number" },
        "category": { "type": "string", "enum": ["Morning Progress", "Interval Time", "End of School", "Special Occasion"] },
        "teacherId": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["prefectId", "timestamp", "category", "teacherId", "date"]
    },
    "Report": {
      "title": "Report",
      "description": "Disciplinary incident report.",
      "type": "object",
      "properties": {
        "prefectId": { "type": "string" },
        "teacherId": { "type": "string" },
        "timestamp": { "type": "number" },
        "type": { "type": "string", "enum": ["Late", "Absent", "Misconduct", "Duty failure", "Other"] },
        "details": { "type": "string" }
      },
      "required": ["prefectId", "teacherId", "timestamp", "type", "details"]
    }
  },
  "firestore": {
    "/prefects/{prefectId}": { "schema": "Prefect", "description": "Master prefect registry." },
    "/attendance/{attendanceId}": { "schema": "Attendance", "description": "Immuntable scan logs." },
    "/reports/{reportId}": { "schema": "Report", "description": "Disciplinary reports." },
    "/authorized_users/{email}": { "schema": "object", "description": "Staff access control list." }
  }
}
