rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function getAuthData() {
      return get(/databases/$(database)/documents/authorized_users/$(request.auth.token.email)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'pixstudios.lk@gmail.com' || 
        getAuthData().role == 'admin'
      );
    }

    function isTeacher() {
      return isSignedIn() && (getAuthData().role == 'teacher' || isAdmin());
    }

    match /prefects/{prefectId} {
      allow read: if isTeacher();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      // Attendance is immutable: created once, never updated or deleted
      allow read: if isTeacher();
      allow create: if isTeacher() 
        && request.resource.data.timestamp == request.time
        && request.resource.data.teacherId == request.auth.uid;
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isTeacher() 
        && request.resource.data.teacherId == request.auth.uid;
    }

    match /authorized_users/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
